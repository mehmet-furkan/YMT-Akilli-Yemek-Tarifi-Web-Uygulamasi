# Copy this file to backend/.env and fill in real values.
# .env is gitignored — do NOT commit it.

NODE_ENV=development
PORT=5001

# MongoDB connection string. For Docker compose use: mongodb://mongo:27017/nightcodekitchen
MONGO_URI=mongodb://localhost:27017/nightcodekitchen

# Generate with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-character-random-hex
JWT_EXPIRE=7d

# Frontend origin for CORS. Vite dev server defaults to 3000 (configured in vite.config.ts).
CLIENT_URL=http://localhost:3000

# Optional (Faz 2):
# LOG_LEVEL=info
