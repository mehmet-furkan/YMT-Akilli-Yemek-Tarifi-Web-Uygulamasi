# MongoDB bağlantı URL'i
# Örnek: mongodb://localhost:27017/ymt-akilli-yemek
# Atlas için: mongodb+srv://<user>:<password>@cluster.mongodb.net/ymt-akilli-yemek
MONGO_URI=mongodb://localhost:27017/ymt-akilli-yemek

# Node ortamı (development / production)
NODE_ENV=development

# Sunucu portu
PORT=5000

# JWT secret anahtarı (en az 32 karakter)
JWT_SECRET=ymt_super_secret_key_change_me_in_production
