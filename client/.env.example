# Backend API'nin tam URL'i.
# Yerel geliştirmede boş bırakabilirsiniz: vite.config.ts'deki proxy /api isteklerini
# otomatik olarak http://localhost:5001'e yönlendirir.
# Production'da: VITE_API_URL=https://api.nightcodekitchen.app/api
VITE_API_URL=http://localhost:5001/api

# Google OAuth Client ID — "Sign in with Google" butonu için zorunlu.
# Backend'deki GOOGLE_CLIENT_ID ile AYNI değer olmalıdır (aynı OAuth client).
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# (Web application) üzerinden alınır. Authorized JavaScript origins'a sitenin
# tam URL'i (localhost:3000 + canlı Vercel URL) eklenmelidir.
# Boş bırakılırsa Google butonu render edilir ama tıklayınca hata verir.
VITE_GOOGLE_CLIENT_ID=
